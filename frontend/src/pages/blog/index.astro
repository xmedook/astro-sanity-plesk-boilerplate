---
import LandingLayout from "../../layouts/LandingLayout.astro";
import HomeHeader from "../../components/home/HomeHeader.astro";
import PostCard from "../../components/blog/PostCard.astro";
import WhatsAppFab from "../../components/express/WhatsAppFab.astro";
import { getPosts } from "../../utils/sanity";

const posts = await getPosts();
const categories = [...new Set(posts.map((p) => p.category).filter(Boolean))] as string[];

const title = "Blog — guías de sitios web y marketing para negocios | cheapweb.mx";
const description =
  "Guías prácticas sobre sitios web, SEO, e-commerce y marketing para negocios en México. Sin tecnicismos, directo al grano.";
---

<LandingLayout title={title} description={description}>
  <Fragment slot="head">
    <meta name="robots" content="index, follow" />
  </Fragment>

  <HomeHeader />

  <main class="px-5 pb-24 pt-14 md:px-8 md:pt-20">
    <div class="mx-auto max-w-6xl">
      <header class="max-w-2xl">
        <h1 class="font-display text-[clamp(2.5rem,7vw,4rem)] font-extrabold leading-[0.95] tracking-[-0.03em] text-balance text-ink">
          Aprendé antes de <span class="text-purple">decidir.</span>
        </h1>
        <p class="mt-5 text-lg leading-relaxed text-ink-dim text-pretty">
          Guías directas sobre sitios web, SEO, e-commerce y marketing para negocios
          en México. Sin tecnicismos, sin relleno.
        </p>
      </header>

      {
        categories.length > 0 && (
          <nav class="mt-9 flex flex-wrap gap-2" aria-label="Filtrar por categoría">
            <button
              type="button"
              data-filter="all"
              class="cat-btn is-active rounded-pill border border-purple bg-purple/15 px-4 py-1.5 text-sm font-medium text-ink transition-colors"
            >
              Todos
            </button>
            {categories.map((cat) => (
              <button
                type="button"
                data-filter={cat}
                class="cat-btn rounded-pill border border-border-solid px-4 py-1.5 text-sm text-ink-dim transition-colors hover:border-purple-dark hover:text-ink"
              >
                {cat}
              </button>
            ))}
          </nav>
        )
      }

      <div id="post-grid" class="mt-10 grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {posts.map((post) => <PostCard post={post} />)}
      </div>

      <p id="post-empty" class="mt-12 hidden text-center text-ink-dim">
        No hay artículos en esta categoría todavía.
      </p>
    </div>
  </main>

  <footer class="border-t border-border-solid px-5 py-12 md:px-8">
    <div class="mx-auto flex max-w-6xl flex-col items-center justify-between gap-5 text-center sm:flex-row sm:text-left">
      <p class="font-display text-lg font-bold text-ink">cheapweb<span class="text-purple">.mx</span></p>
      <nav class="flex flex-wrap items-center justify-center gap-x-6 gap-y-2 text-sm" aria-label="Pie de página">
        <a href="/" class="text-ink-dim transition-colors hover:text-ink">Inicio</a>
        <a href="/#planes" class="text-ink-dim transition-colors hover:text-ink">Planes</a>
        <a href="/express" class="text-ink-dim transition-colors hover:text-ink">Landing Express</a>
        <a href="/demos" class="text-ink-dim transition-colors hover:text-ink">Demos</a>
      </nav>
    </div>
  </footer>

  <WhatsAppFab />
</LandingLayout>

<script>
  const buttons = document.querySelectorAll<HTMLButtonElement>(".cat-btn");
  const cards = document.querySelectorAll<HTMLElement>("#post-grid > [data-category]");
  const empty = document.getElementById("post-empty");

  const activeCls = ["is-active", "border-purple", "bg-purple/15", "text-ink"];
  const idleCls = ["border-border-solid", "text-ink-dim"];

  function setActive(btn: HTMLButtonElement) {
    buttons.forEach((b) => {
      b.classList.remove(...activeCls);
      b.classList.add(...idleCls);
    });
    btn.classList.remove(...idleCls);
    btn.classList.add(...activeCls);
  }

  buttons.forEach((btn) => {
    btn.addEventListener("click", () => {
      const filter = btn.dataset.filter;
      setActive(btn);
      let visible = 0;
      cards.forEach((card) => {
        const show = filter === "all" || card.dataset.category === filter;
        card.classList.toggle("hidden", !show);
        if (show) visible++;
      });
      empty?.classList.toggle("hidden", visible > 0);
    });
  });
</script>
