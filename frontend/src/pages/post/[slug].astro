---
import { PortableText } from "astro-portabletext";
import { createDataAttribute } from "@sanity/visual-editing-csm";
import CodeBlock from "../../components/CodeBlock.astro";
import PortableImage from "../../components/PortableImage.astro";
import Layout from "../../layouts/Layout.astro";
import { formatDate } from "../../utils";
import { urlFor, buildSrcSet } from "../../utils/image";
import { getPost, getPosts } from "../../utils/sanity";

// SSG: enumerate post slugs at build time. With placeholder Sanity creds
// this returns [] and no slug routes are generated.
export async function getStaticPaths() {
  const posts = await getPosts();
  return posts
    .filter((p) => p?.slug?.current)
    .map((p) => ({ params: { slug: p.slug.current } }));
}

const { slug } = Astro.params;
const post = await getPost(slug!);

if (!post) {
  return Astro.rewrite('/404');
}

const visualEditingEnabled =
  import.meta.env.PUBLIC_SANITY_VISUAL_EDITING_ENABLED === "true";

const dataAttr = visualEditingEnabled
  ? createDataAttribute({
      projectId: import.meta.env.PUBLIC_SANITY_STUDIO_PROJECT_ID,
      dataset: import.meta.env.PUBLIC_SANITY_STUDIO_DATASET,
      baseUrl:
        import.meta.env.PUBLIC_SANITY_STUDIO_URL || "http://localhost:3333",
      id: post._id,
      type: post._type,
    })
  : null;

// SEO values: use editor-provided overrides, fall back to post fields
const seoTitle = post.seo?.metaTitle || post.title;
const seoDescription = post.seo?.metaDescription || post.excerpt;
const ogImageSource = post.seo?.ogImage ?? post.mainImage;
const ogImage = ogImageSource
  ? urlFor(ogImageSource).width(1200).height(630).fit("crop").auto("format").quality(80).url()
  : undefined;
---

<Layout
  title={seoTitle ?? "Post"}
  description={seoDescription}
  image={ogImage}
>
  <article class="mb-16">
    <!-- Eyebrow: back link · category · date · read time -->
    <div class="mb-6 flex flex-wrap items-center gap-x-2 gap-y-1 text-xs font-semibold uppercase tracking-[0.08em]">
      <a href="/blog" class="text-purple-light no-underline transition-colors hover:text-purple">← Volver al blog</a>
      {post.category && <span class="text-muted" aria-hidden="true">·</span>}
      {post.category && <span class="text-purple-light">{post.category}</span>}
      <span class="text-muted" aria-hidden="true">·</span>
      <span class="normal-case text-ink-dim">{formatDate(post.publishedAt ?? post._createdAt)}</span>
      {post.readTime && <span class="text-muted" aria-hidden="true">·</span>}
      {post.readTime && <span class="normal-case text-ink-dim">{post.readTime}</span>}
    </div>

    <h1 class="font-display text-4xl font-extrabold leading-[1.05] tracking-[-0.02em] text-balance text-ink md:text-5xl">{post.title}</h1>

    {post.excerpt && (
      <p class="mt-5 font-serif text-xl leading-relaxed text-pretty text-ink-dim md:text-2xl" data-sanity={dataAttr?.scope("excerpt").toString()}>
        {post.excerpt}
      </p>
    )}

    {
      post.mainImage && (
        <img
          class="mt-8 aspect-[16/9] w-full rounded-card border border-border-solid object-cover"
          src={urlFor(post.mainImage).width(768).auto("format").quality(80).url()}
          srcset={buildSrcSet(post.mainImage, [480, 768, 1200], 80)}
          sizes="(max-width: 768px) 100vw, 768px"
          width={post.mainImage.width}
          height={post.mainImage.height}
          style={post.mainImage.lqip ? `background-image:url(${post.mainImage.lqip});background-size:cover;background-position:center` : undefined}
          loading="eager"
          fetchpriority="high"
          decoding="async"
          alt={post.mainImage.alt || post.title || ""}
          data-sanity={dataAttr?.scope("mainImage").toString()}
        />
      )
    }

    <div class="prose prose-lg prose-serif prose-invert mt-10 max-w-none prose-headings:font-display prose-headings:text-ink prose-blockquote:border-l-[5px] prose-blockquote:border-purple prose-blockquote:pl-4 prose-blockquote:not-italic prose-blockquote:text-ink prose-a:text-purple-light prose-a:underline prose-a:underline-offset-2 hover:prose-a:text-purple" data-sanity={dataAttr?.scope("body").toString()}>
      <PortableText value={post.body} components={{ type: { code: CodeBlock, image: PortableImage } }} />
    </div>
  </article>
</Layout>
