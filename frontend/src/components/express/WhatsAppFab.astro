---
/**
 * Floating WhatsApp pill — persistent secondary path to a human. Bottom-right,
 * above content, clear of the iOS safe area. `mobileHidden` hides it under md
 * (e.g. on home, where a mobile CTA bar already owns the bottom edge).
 */
import { express } from "../../config/express";

interface Props {
  mobileHidden?: boolean;
}
const { mobileHidden = false } = Astro.props;
---

<a
  href={express.whatsappUrl}
  target="_blank"
  rel="noopener noreferrer"
  data-ga="click_cta_express"
  aria-label="Hablar por WhatsApp"
  class:list={[
    "fixed bottom-5 right-5 z-40 items-center gap-2 rounded-pill border border-purple/40 bg-surface/90 py-3 pl-3 pr-4 text-sm font-semibold text-ink shadow-[0_8px_28px_rgba(0,0,0,0.45)] backdrop-blur-md transition-all duration-200 ease-out hover:-translate-y-0.5 hover:border-purple hover:shadow-[var(--shadow-hover-lift)] focus-visible:outline-none focus-visible:ring-[3px] focus-visible:ring-purple/60",
    mobileHidden ? "hidden md:flex" : "flex",
  ]}
  style="margin-bottom: env(safe-area-inset-bottom);"
>
  <svg class="h-6 w-6 text-purple-light" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
    <path d="M12.04 2C6.58 2 2.13 6.45 2.13 11.91c0 1.75.46 3.46 1.32 4.97L2 22l5.25-1.38a9.9 9.9 0 0 0 4.79 1.22h.01c5.46 0 9.91-4.45 9.91-9.91 0-2.65-1.03-5.14-2.9-7.01A9.82 9.82 0 0 0 12.04 2Zm0 1.82c2.16 0 4.19.84 5.72 2.37a8.02 8.02 0 0 1 2.37 5.72c0 4.46-3.63 8.09-8.1 8.09a8.1 8.1 0 0 1-4.13-1.13l-.3-.18-3.06.8.82-2.98-.2-.31a8.07 8.07 0 0 1-1.24-4.29c0-4.46 3.63-8.09 8.1-8.09Zm-2.5 4.34c-.18 0-.47.07-.72.34-.25.27-.95.93-.95 2.27s.97 2.63 1.11 2.81c.14.18 1.92 2.93 4.65 4.11.65.28 1.16.45 1.55.58.65.21 1.25.18 1.72.11.52-.08 1.62-.66 1.85-1.3.23-.64.23-1.18.16-1.3-.07-.11-.25-.18-.52-.32-.27-.14-1.62-.8-1.87-.89-.25-.09-.43-.14-.62.14-.18.27-.71.89-.87 1.07-.16.18-.32.2-.59.07-.27-.14-1.15-.42-2.19-1.35-.81-.72-1.36-1.61-1.52-1.88-.16-.27-.02-.42.12-.55.12-.12.27-.32.41-.48.14-.16.18-.27.27-.45.09-.18.05-.34-.02-.48-.07-.14-.61-1.49-.84-2.04-.22-.53-.45-.46-.62-.47l-.53-.01Z" />
  </svg>
  <span class="hidden sm:inline">WhatsApp</span>
</a>
