---
/**
 * S09 · Final CTA. The closing offer: anchored price, the deal in four lines,
 * dual CTA. Sits on a plum-lit panel — the page's loudest moment, earned.
 */
import { express, checkoutHref, stripeReady } from "../../config/express";
import Cta from "./Cta.astro";

const { price, priceAnchor, savings, deliveryDays, whatsappUrl, guarantee100, cupos } =
  express;

const bullets = [
  "WordPress + dominio + hosting + 5 correos + GA4 + Pixel",
  guarantee100
    ? `${deliveryDays} días hábiles garantizados o te devolvemos el 100%`
    : `${deliveryDays} días hábiles garantizados`,
  stripeReady
    ? "Stripe seguro. Sin tarjeta guardada. Sin contratos."
    : "Pago seguro. Sin tarjeta guardada. Sin contratos.",
  `Tomamos ${cupos.total} proyectos por semana para cuidar la calidad.`,
];
---

<section class="px-5 py-20 md:px-8 md:py-28">
  <div
    class="relative mx-auto max-w-3xl overflow-hidden rounded-[1.5rem] border border-purple/40 bg-surface px-6 py-12 text-center shadow-[0_0_60px_-20px_rgba(130,36,227,0.5)] md:px-12 md:py-16"
  >
    <div
      aria-hidden="true"
      class="pointer-events-none absolute -top-24 left-1/2 h-72 w-72 -translate-x-1/2 rounded-full opacity-60 blur-3xl"
      style="background: radial-gradient(circle, rgba(130,36,227,0.5) 0%, rgba(130,36,227,0) 70%);"
    >
    </div>

    <div class="relative">
      <h2
        class="font-display text-[clamp(2rem,6vw,3.5rem)] font-extrabold leading-[0.95] tracking-[-0.03em] text-balance text-ink"
      >
        Landing Express.
      </h2>

      <div class="mt-6 flex items-end justify-center gap-3">
        <span class="font-display text-lg text-muted line-through">{priceAnchor} MXN</span>
        <span class="font-display text-5xl font-extrabold tracking-[-0.03em] text-purple md:text-6xl">
          {price}
        </span>
      </div>
      <p class="mt-2 text-sm font-semibold uppercase tracking-[0.08em] text-purple-light">
        {savings}
      </p>

      <ul class="mx-auto mt-8 max-w-md space-y-3 text-left">
        {
          bullets.map((bullet) => (
            <li class="flex items-start gap-3 text-ink-dim">
              <svg class="mt-1 h-4 w-4 shrink-0 text-purple-light" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                <path d="M13 4 6 12l-3-3" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
              <span>{bullet}</span>
            </li>
          ))
        }
      </ul>

      <div class="mt-10 flex flex-col items-center justify-center gap-3 sm:flex-row">
        <Cta href={checkoutHref()} event="checkout_started" pulse external={stripeReady}>
          Empezar mi sitio · Pagar {price} <span aria-hidden="true">→</span>
        </Cta>
        <Cta href={whatsappUrl} variant="ghost" event="click_cta_express" external>
          ¿Dudas antes? Háblanos por WhatsApp
        </Cta>
      </div>
    </div>
  </div>
</section>
