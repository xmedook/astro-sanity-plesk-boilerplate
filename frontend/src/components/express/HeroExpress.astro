---
/**
 * S01 · Hero. The page's first fold: price-forward, two CTAs, trust bullets.
 * Contained violet radial glow (CSS, no JS, no ogl) — atmosphere without weight.
 */
import { express, checkoutHref, stripeReady } from "../../config/express";
import Cta from "./Cta.astro";

const { price, priceAnchor, deliveryDays, whatsappUrl, guarantee100 } = express;

const trustBullets = [
  "Pago único · sin contratos",
  guarantee100
    ? `Si no entregamos en ${deliveryDays} días, te devolvemos el 100%`
    : `Entrega en ${deliveryDays} días hábiles`,
  "WordPress editable — tuyo para siempre",
  "GA4 + Meta Pixel configurados desde el día 1",
];
---

<section class="relative overflow-hidden px-5 pb-20 pt-16 md:px-8 md:pb-28 md:pt-24">
  <!-- Atmosphere: single contained plum glow, top-right. -->
  <div
    aria-hidden="true"
    class="pointer-events-none absolute -right-40 -top-40 h-[34rem] w-[34rem] rounded-full opacity-70 blur-3xl"
    style="background: radial-gradient(circle, rgba(130,36,227,0.45) 0%, rgba(130,36,227,0) 70%);"
  >
  </div>

  <div class="relative mx-auto max-w-3xl text-center">
    <p
      class="mb-7 inline-flex items-center gap-2 rounded-pill border border-purple/40 bg-purple/10 px-4 py-1.5 text-sm font-medium text-ink"
    >
      <span aria-hidden="true">🔥</span>
      Precio piloto · termina pronto
    </p>

    <h1
      class="font-display text-[clamp(2.5rem,8vw,4.5rem)] font-extrabold leading-[0.95] tracking-[-0.03em] text-balance text-ink"
    >
      Tu sitio web profesional por <span class="text-purple">{price} MXN</span>.
    </h1>

    <p class="mt-5 font-display text-2xl font-bold text-ink md:text-3xl">
      Listo en {deliveryDays} días. Con tracking incluido.
    </p>

    <p class="mx-auto mt-5 max-w-xl text-lg leading-relaxed text-ink-dim text-pretty">
      Normalmente desde {priceAnchor} MXN. Hoy {price}. WordPress + dominio +
      hosting + GA4 + Pixel.
      {stripeReady ? " Pago seguro con Stripe." : " Pago seguro."}
    </p>

    <div class="mt-9 flex flex-col items-center justify-center gap-3 sm:flex-row">
      <Cta href={checkoutHref()} event="checkout_started" pulse external={stripeReady}>
        Pagar {price} con Stripe
        <span aria-hidden="true">→</span>
      </Cta>
      <Cta href={whatsappUrl} variant="ghost" event="click_cta_express" external>
        ¿Dudas? Hablar por WhatsApp
      </Cta>
    </div>

    <ul class="mx-auto mt-10 grid max-w-xl gap-x-6 gap-y-3 text-left sm:grid-cols-2">
      {
        trustBullets.map((bullet) => (
          <li class="flex items-start gap-2.5 text-[0.95rem] text-ink-dim">
            <svg
              class="mt-0.5 h-5 w-5 shrink-0 text-purple-light"
              viewBox="0 0 20 20"
              fill="none"
              aria-hidden="true"
            >
              <path
                d="M16.5 5.5 8 14 3.5 9.5"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              />
            </svg>
            <span>{bullet}</span>
          </li>
        ))
      }
    </ul>
  </div>
</section>
