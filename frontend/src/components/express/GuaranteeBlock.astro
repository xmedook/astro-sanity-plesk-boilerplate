---
/**
 * Trust centerpiece: the delivery guarantee, stated boldly. Factual (not an
 * invented testimonial). Renders a softer reassurance when guarantee100 is off.
 */
import { express } from "../../config/express";

const { deliveryDays, guarantee100 } = express;
---

<section class="px-5 py-16 md:px-8 md:py-20">
  <div
    class="relative mx-auto flex max-w-3xl flex-col items-center gap-6 overflow-hidden rounded-[1.5rem] border border-purple/40 bg-surface px-6 py-12 text-center md:flex-row md:gap-8 md:px-12 md:text-left"
  >
    <div
      aria-hidden="true"
      class="pointer-events-none absolute -left-20 top-1/2 h-64 w-64 -translate-y-1/2 rounded-full opacity-50 blur-3xl"
      style="background: radial-gradient(circle, rgba(130,36,227,0.45) 0%, rgba(130,36,227,0) 70%);"
    >
    </div>

    <!-- Shield mark -->
    <div class="relative shrink-0">
      <div
        class="flex h-20 w-20 items-center justify-center rounded-full border border-purple/50 bg-bg/60"
      >
        <svg class="h-10 w-10 text-purple-light" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path
            d="M12 2.5 4 5.5v6c0 4.4 3.1 8.5 8 10 4.9-1.5 8-5.6 8-10v-6L12 2.5Z"
            stroke="currentColor"
            stroke-width="1.6"
            stroke-linejoin="round"
          />
          <path
            d="m8.5 12 2.4 2.4 4.6-4.8"
            stroke="currentColor"
            stroke-width="1.8"
            stroke-linecap="round"
            stroke-linejoin="round"
          />
        </svg>
      </div>
    </div>

    <div class="relative">
      <h2 class="font-display text-2xl font-extrabold leading-tight text-ink md:text-3xl">
        {
          guarantee100
            ? `Entregamos en ${deliveryDays} días o te devolvemos el 100%.`
            : `Entregamos en ${deliveryDays} días hábiles, garantizado.`
        }
      </h2>
      <p class="mt-3 leading-relaxed text-ink-dim text-pretty">
        El reloj arranca cuando recibimos tu brief completo. Aceptamos máximo
        5 sitios por semana justamente para poder cumplirlo
        {guarantee100 ? " — y respaldarlo con tu dinero de vuelta." : "."}
      </p>
    </div>
  </div>
</section>
