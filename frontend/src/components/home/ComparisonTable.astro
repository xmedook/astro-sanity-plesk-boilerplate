---
/**
 * H07 · Comparison table. cheapweb.mx column is visually highlighted (plum
 * tint). Scrolls horizontally on small screens rather than cramping. Booking CTA.
 */
import { bookingHref, bookingReady } from "../../config/home";

const columns = ["cheapweb.mx", "Freelancer", "Agencia", "Wix / DIY"];
const rows = [
  { label: "Entrega", values: ["12–28 días", "2–8 semanas", "1–4 meses", "Indefinido"] },
  { label: "Diseño personalizado", values: ["Sí", "A veces", "Sí", "Template"] },
  { label: "Dominio + hosting", values: ["Incluido 1 año", "Negociable", "Factura aparte", "Factura aparte"] },
  { label: "Mobile-first", values: ["Sí", "A veces", "Sí", "Básico"] },
  { label: "SEO configurado", values: ["Sí", "Casi nunca", "Sí", "Tú lo haces"] },
  { label: "WhatsApp + CTA", values: ["Sí", "Si lo pedís", "Sí", "Tú configurás"] },
  { label: "Soporte post-entrega", values: ["Opcional", "Si hay suerte", "Caro", "No existe"] },
  { label: "Inversión total", values: ["$8K–$24K", "$3K–$15K", "$25K–$80K", "$0 + 40–100h"] },
];
---

<section class="px-5 py-20 md:px-8 md:py-28">
  <div class="mx-auto max-w-5xl">
    <h2
      class="font-display text-[clamp(1.875rem,4.5vw,2.75rem)] font-bold leading-[1.05] tracking-[-0.02em] text-balance text-ink"
    >
      Compáralo tú mismo.
    </h2>

    <div class="relative mt-10">
      <div class="overflow-x-auto">
        <table class="w-full min-w-[640px] border-separate border-spacing-0 text-left">
        <thead>
          <tr>
            <th scope="col" class="w-[28%] px-4 py-4"></th>
            {
              columns.map((col, i) => (
                <th
                  scope="col"
                  class:list={[
                    "px-4 py-4 text-center font-display text-base font-bold",
                    i === 0
                      ? "rounded-t-card bg-purple/15 text-purple-light"
                      : "text-ink-dim",
                  ]}
                >
                  {col}
                </th>
              ))
            }
          </tr>
        </thead>
        <tbody>
          {
            rows.map((row, r) => (
              <tr>
                <th
                  scope="row"
                  class="border-t border-border-solid px-4 py-3.5 text-sm font-semibold text-ink"
                >
                  {row.label}
                </th>
                {row.values.map((val, i) => (
                  <td
                    class:list={[
                      "border-t border-border-solid px-4 py-3.5 text-center text-sm",
                      i === 0
                        ? "bg-purple/10 font-semibold text-ink"
                        : "text-ink-dim",
                      r === rows.length - 1 && i === 0 && "rounded-b-card",
                    ]}
                  >
                    {i === 0 && <span class="text-purple-light" aria-hidden="true">✓ </span>}
                    {val}
                  </td>
                ))}
              </tr>
            ))
          }
        </tbody>
      </table>
      </div>

      <!-- Scroll affordance on narrow screens: right fade + hint. -->
      <div
        aria-hidden="true"
        class="pointer-events-none absolute inset-y-0 right-0 w-12 bg-gradient-to-l from-bg to-transparent lg:hidden"
      >
      </div>
    </div>

    <p class="mt-3 flex items-center justify-center gap-1.5 text-sm text-ink-dim lg:hidden">
      Deslizá para comparar <span aria-hidden="true">→</span>
    </p>

    <div class="mt-10 text-center">
      <a
        href={bookingHref()}
        data-ga="click_cta_tidycal"
        {...bookingReady ? { target: "_blank", rel: "noopener noreferrer" } : {}}
        class="inline-flex items-center justify-center gap-2 rounded-pill bg-purple px-7 py-4 text-base font-semibold text-white transition-all duration-200 ease-out hover:-translate-y-0.5 hover:bg-purple-dark hover:shadow-[var(--shadow-hover-lift)] focus-visible:outline-none focus-visible:ring-[3px] focus-visible:ring-purple/60 md:text-lg"
      >
        La diferencia es clara. ¿Hablamos? <span aria-hidden="true">→</span>
      </a>
    </div>
  </div>
</section>
