---
/**
 * H03 · Services. What's actually in every build — concrete deliverables, not
 * generic "we make websites" copy. Four areas, asymmetric (not an icon grid).
 */
const services = [
  {
    title: "Diseño a medida, no plantilla",
    body: "Mobile-first, pensado para que tu visita encuentre el botón de contacto en 3 segundos. Apruebas el diseño antes de que escribamos una línea de código.",
    points: ["Diseño custom por negocio", "Mobile-first real", "CTA y WhatsApp visibles"],
  },
  {
    title: "WordPress que editas tú",
    body: "Nada de plataformas cerradas. Tu sitio es WordPress: cambiás textos, fotos y precios sin pagarle a nadie. Te capacitamos para que seas autónomo.",
    points: ["100% tuyo y editable", "Capacitación incluida", "Sin dependencia de nosotros"],
  },
  {
    title: "Listo para ser encontrado",
    body: "SEO on-page configurado desde el día uno: títulos, meta, estructura H1, Analytics y Search Console. Para que Google te muestre y sepas qué funciona.",
    points: ["SEO on-page", "Google Analytics + Search Console", "Estructura indexable"],
  },
  {
    title: "Todo incluido, un solo pago",
    body: "Dominio, hosting un año, SSL y correos corporativos vienen dentro. Sin mensualidades obligatorias ni facturas sorpresa después.",
    points: ["Dominio + hosting 1 año", "SSL y correos", "Pago único, sin contratos"],
  },
];
---

<section class="px-5 py-20 md:px-8 md:py-28">
  <div class="mx-auto max-w-5xl">
    <h2
      class="max-w-2xl font-display text-[clamp(1.875rem,4.5vw,2.75rem)] font-bold leading-[1.05] tracking-[-0.02em] text-balance text-ink"
    >
      Lo que entra en cada sitio que entregamos.
    </h2>

    <div class="mt-12 grid gap-5 md:grid-cols-2">
      {
        services.map((service, i) => (
          <div
            data-reveal
            style={`--rd:${i * 80}ms`}
            class="flex flex-col rounded-card border border-border-solid bg-surface p-7 transition-colors duration-200 hover:border-purple/40 md:p-8"
          >
            <h3 class="font-display text-xl font-bold text-ink">{service.title}</h3>
            <p class="mt-3 leading-relaxed text-ink-dim text-pretty">{service.body}</p>
            <ul class="mt-5 flex flex-wrap gap-2">
              {service.points.map((point) => (
                <li class="inline-flex items-center gap-1.5 rounded-pill border border-border-solid bg-bg/50 px-3 py-1.5 text-sm text-ink">
                  <svg class="h-3.5 w-3.5 shrink-0 text-purple-light" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                    <path d="M13 4 6 12l-3-3" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                  </svg>
                  {point}
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>
  </div>
</section>
