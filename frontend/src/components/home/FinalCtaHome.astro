---
/**
 * H14 · Final CTA (home). The closing ask on a plum-lit panel: reassurance,
 * honest urgency (cupos + next opening), book / WhatsApp.
 */
import { home, bookingHref, bookingReady } from "../../config/home";
import Cta from "../express/Cta.astro";

const { cupos, whatsappUrl } = home;
---

<section class="px-5 py-20 md:px-8 md:py-28">
  <div
    class="relative mx-auto max-w-3xl overflow-hidden rounded-[1.5rem] border border-purple/40 bg-surface px-6 py-12 text-center shadow-[0_0_60px_-20px_rgba(130,36,227,0.5)] md:px-12 md:py-16"
  >
    <div
      aria-hidden="true"
      class="pointer-events-none absolute -top-24 left-1/2 h-72 w-72 -translate-x-1/2 rounded-full opacity-60 blur-3xl"
      style="background: radial-gradient(circle, rgba(130,36,227,0.5) 0%, rgba(130,36,227,0) 70%);"
    >
    </div>

    <div class="relative">
      <h2
        class="font-display text-[clamp(2rem,6vw,3.5rem)] font-extrabold leading-[0.95] tracking-[-0.03em] text-balance text-ink"
      >
        ¿Listo para tener tu sitio web?
      </h2>

      <p class="mx-auto mt-5 max-w-xl text-lg leading-relaxed text-ink-dim text-pretty">
        Aprobás el diseño al 100% antes de desarrollar. Y si no estás conforme con
        lo entregado, te devolvemos. Sin contratos eternos, sin letra chica.
      </p>

      <p
        class="mx-auto mt-6 inline-flex flex-wrap items-center justify-center gap-2 rounded-pill border border-purple/40 bg-purple/10 px-4 py-2 text-sm font-medium text-ink"
      >
        <span class="font-bold text-white">{cupos.total} cupos {cupos.period}</span>
        <span class="text-ink-dim">· {cupos.reserved} ya reservados · el siguiente abre en {cupos.nextOpens}</span>
      </p>

      <div class="mt-9 flex flex-col items-center justify-center gap-3 sm:flex-row">
        <Cta href={bookingHref()} event="click_cta_tidycal" pulse external={bookingReady}>
          Agenda 15 min con Alejandro <span aria-hidden="true">→</span>
        </Cta>
        <Cta href={whatsappUrl} variant="ghost" event="click_cta_whatsapp" external>
          Hablar por WhatsApp
        </Cta>
      </div>
    </div>
  </div>
</section>
