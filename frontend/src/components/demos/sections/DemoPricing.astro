---
import type { DemoSection } from "../../../utils/sanity";

interface Props {
  section: DemoSection;
  contactHref: string;
}

const { section, contactHref } = Astro.props;
const plans = section.plans ?? [];
---

<section id="precios" class="scroll-mt-24 py-16">
  <div class="mx-auto max-w-2xl text-center">
    {section.heading && (
      <h2 class="font-display text-3xl font-bold leading-tight tracking-[-0.02em] text-balance text-ink sm:text-4xl">
        {section.heading}
      </h2>
    )}
    {section.subheading && <p class="mt-4 text-lg leading-7 text-ink-dim">{section.subheading}</p>}
  </div>

  <div class="mt-12 grid items-stretch gap-6 sm:grid-cols-2 lg:grid-cols-3">
    {
      plans.map((plan) => (
        <div
          class:list={[
            "relative flex flex-col rounded-card border p-7 transition-transform duration-200",
            plan.highlighted
              ? "border-purple bg-elevated shadow-[0_24px_48px_rgba(0,0,0,0.35)] lg:-translate-y-2"
              : "border-border-solid bg-surface",
          ]}
        >
          {plan.highlighted && (
            <span class="absolute -top-3 left-7 rounded-pill bg-purple px-3 py-1 text-xs font-bold uppercase tracking-[0.08em] text-white">
              Recomendado
            </span>
          )}
          <h3 class="font-display text-xl font-bold text-ink">{plan.name}</h3>
          {plan.description && <p class="mt-1 text-sm text-ink-dim">{plan.description}</p>}
          <p class="mt-5 flex items-baseline gap-1">
            <span class="font-display text-4xl font-extrabold tracking-[-0.03em] text-ink">{plan.price}</span>
            {plan.period && <span class="text-sm text-muted">{plan.period}</span>}
          </p>
          {plan.features && plan.features.length > 0 && (
            <ul class="mt-6 flex flex-1 flex-col gap-2.5">
              {plan.features.map((f) => (
                <li class="flex items-start gap-2.5 text-sm text-ink-dim">
                  <span class="mt-0.5 text-purple-light" aria-hidden="true">
                    ✓
                  </span>
                  {f}
                </li>
              ))}
            </ul>
          )}
          <a
            href={contactHref}
            class:list={[
              "mt-7 rounded-pill px-5 py-3 text-center font-semibold no-underline transition-colors",
              plan.highlighted
                ? "bg-purple text-white hover:bg-purple-dark"
                : "border border-border-solid text-ink hover:border-purple",
            ]}
          >
            {plan.cta || "Elegir"}
          </a>
        </div>
      ))
    }
  </div>
</section>
