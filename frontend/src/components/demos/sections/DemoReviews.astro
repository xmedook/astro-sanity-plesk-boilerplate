---
import type { DemoSection } from "../../../utils/sanity";

interface Props {
  section: DemoSection;
}

const { section } = Astro.props;
const reviews = section.items ?? [];
const rating = section.rating ?? 4.9;
const total = section.totalReviews ?? reviews.length;

// Whole + half star count for the summary row
const full = Math.floor(rating);
const half = rating - full >= 0.5;

// Deterministic avatar tint per author (no asset needed)
const tints = ["#7E57C2", "#26A69A", "#EF6C00", "#5C6BC0", "#EC407A", "#00897B"];
const tintFor = (name: string) => tints[(name?.charCodeAt(0) || 0) % tints.length];
---

<section id="resenas" class="scroll-mt-24 py-16">
  {section.heading && (
    <h2 class="mb-8 font-display text-3xl font-bold leading-tight tracking-[-0.02em] text-balance text-ink sm:text-4xl">
      {section.heading}
    </h2>
  )}

  {/* GMB-style widget — light card embedded in the dark page */}
  <div class="rounded-card bg-white p-6 text-gray-800 shadow-[0_24px_48px_rgba(0,0,0,0.35)] sm:p-8">
    <div class="flex flex-wrap items-center gap-4 border-b border-gray-200 pb-6">
      <svg width="36" height="36" viewBox="0 0 24 24" aria-hidden="true">
        <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 0 1-2.2 3.32v2.77h3.57c2.08-1.92 3.27-4.74 3.27-8.1Z"/>
        <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.99.66-2.26 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84A11 11 0 0 0 12 23Z"/>
        <path fill="#FBBC05" d="M5.84 14.1a6.6 6.6 0 0 1 0-4.2V7.06H2.18a11 11 0 0 0 0 9.88l3.66-2.84Z"/>
        <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1A11 11 0 0 0 2.18 7.06l3.66 2.84C6.71 7.31 9.14 5.38 12 5.38Z"/>
      </svg>
      <div>
        <p class="font-display text-base font-bold leading-tight text-gray-900">Reseñas de Google</p>
        <p class="text-sm text-gray-500">Negocio verificado</p>
      </div>
      <div class="ml-auto text-right">
        <p class="font-display text-3xl font-extrabold leading-none text-gray-900">{rating.toFixed(1)}</p>
        <p class="text-base leading-none text-[#fbbc04]" aria-label={`${rating} de 5 estrellas`}>
          {"★".repeat(full)}{half ? "⯨" : ""}<span class="text-gray-300">{"★".repeat(5 - full - (half ? 1 : 0))}</span>
        </p>
        <p class="mt-1 text-xs text-gray-500">{total} reseñas</p>
      </div>
    </div>

    <ul class="mt-6 grid gap-6 sm:grid-cols-3">
      {
        reviews.map((r) => (
          <li class="flex flex-col">
            <div class="flex items-center gap-3">
              <span
                class="flex h-9 w-9 shrink-0 items-center justify-center rounded-full font-display text-sm font-bold text-white"
                style={`background:${tintFor(r.author || "?")}`}
              >
                {(r.author || "?").trim().charAt(0).toUpperCase()}
              </span>
              <div>
                <p class="text-sm font-semibold leading-tight text-gray-900">{r.author}</p>
                <p class="text-xs text-gray-500">{r.time}</p>
              </div>
            </div>
            <p class="mt-2 text-sm leading-none text-[#fbbc04]" aria-label={`${r.rating ?? 5} de 5`}>
              {"★".repeat(r.rating ?? 5)}<span class="text-gray-300">{"★".repeat(5 - (r.rating ?? 5))}</span>
            </p>
            <p class="mt-2 text-sm leading-6 text-gray-700">{r.text}</p>
          </li>
        ))
      }
    </ul>
  </div>
</section>
