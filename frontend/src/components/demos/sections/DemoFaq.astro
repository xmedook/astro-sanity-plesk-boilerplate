---
import type { DemoSection } from "../../../utils/sanity";

interface Props {
  section: DemoSection;
}

const { section } = Astro.props;
// items reuse {question, answer}
const items = (section.items ?? []).filter((i) => i.question);
---

{/* Native <details> accordion — no JS island needed */}
<section id="faq" class="scroll-mt-24 py-16">
  {section.heading && (
    <h2 class="font-display text-3xl font-bold leading-tight text-ink sm:text-4xl">{section.heading}</h2>
  )}
  <div class="mt-8 divide-y divide-border-solid border-y border-border-solid">
    {
      items.map((item) => (
        <details class="group py-4">
          <summary class="flex cursor-pointer list-none items-center justify-between font-display text-lg font-semibold text-ink">
            {item.question}
            <span class="text-purple-light transition-transform duration-200 group-open:rotate-45">+</span>
          </summary>
          {item.answer && <p class="mt-3 text-sm leading-6 text-ink-dim">{item.answer}</p>}
        </details>
      ))
    }
  </div>
</section>
