---
/**
 * PortableText serializer for body images. Resolves the Sanity asset to an
 * optimized, responsive, lazy-loaded <img> (the default renderer would ship the
 * raw full-resolution asset). Used by post/[slug].astro.
 */
import { urlFor, buildSrcSet } from "../utils/image";

const { node } = Astro.props;
const hasAsset = Boolean(node?.asset);
---

{
  hasAsset && (
    <figure class="my-8">
      <img
        class="w-full rounded-card border border-border-solid"
        src={urlFor(node).width(768).auto("format").quality(80).url()}
        srcset={buildSrcSet(node, [480, 768, 1200], 80)}
        sizes="(max-width: 768px) 100vw, 768px"
        width={node.width}
        height={node.height}
        style={node.lqip ? `background-image:url(${node.lqip});background-size:cover;background-position:center` : undefined}
        loading="lazy"
        decoding="async"
        alt={node.alt || ""}
      />
      {node.caption && (
        <figcaption class="mt-3 text-center text-sm text-ink-dim">{node.caption}</figcaption>
      )}
    </figure>
  )
}
